{
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "functions/**"],
    "rewrites": [
      {
        "source": "/auth/ml/callback",
        "function": "mlCallback"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
